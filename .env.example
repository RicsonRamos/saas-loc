# Backend
DATABASE_URL=postgresql+psycopg://locadora:locadora@localhost:5432/locadora
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173

# Storage (S3-compatível; opcional — sem isso os endpoints de anexo ficam indisponíveis).
# docker-compose.yml não sobe nenhum provedor: aponte para Supabase Storage ou um MinIO próprio.
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=locadora
STORAGE_SECRET_KEY=locadora123
STORAGE_REGION=us-east-1

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
